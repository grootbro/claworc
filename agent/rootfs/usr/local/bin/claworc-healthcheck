#!/usr/bin/env bash

set -euo pipefail

mode="${1:-ready}"

check_tcp() {
  local port="$1"
  timeout 2 bash -c ">/dev/tcp/127.0.0.1/${port}" >/dev/null 2>&1
}

check_http() {
  local url="$1"
  curl --silent --show-error --fail --max-time 2 "${url}" >/dev/null
}

check_cdp() {
  curl --silent --show-error --fail --max-time 2 http://127.0.0.1:9222/json/version \
    | grep -q 'webSocketDebuggerUrl'
}

check_ready() {
  check_tcp 22
  check_tcp 18789
  check_http http://127.0.0.1:3000/vnc.html
  check_cdp
}

case "${mode}" in
  ready|startup|live)
    check_ready
    ;;
  *)
    echo "usage: claworc-healthcheck [ready|startup|live]" >&2
    exit 2
    ;;
esac
